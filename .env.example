# ---------------------------------------------------------------------------
# Access gate (the only auth; single shared password for the Cloudsheer team)
# ---------------------------------------------------------------------------
AUTH_SECRET=                 # random string; HMAC key for the gate cookie (npx auth secret, or any long random)
ACCESS_PASSWORD=             # the password the team types to unlock the app

# ---------------------------------------------------------------------------
# Database (Neon free tier Postgres)
# ---------------------------------------------------------------------------
DATABASE_URL=                # postgresql://...  (Neon connection string)

# ---------------------------------------------------------------------------
# X (Twitter) API - free tier. OAuth 2.0 user context with PKCE.
# Create an app at https://developer.x.com, enable OAuth 2.0, set the callback.
# ---------------------------------------------------------------------------
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=              # https://<your-app>.vercel.app/api/x/callback  (and http://localhost:3000/api/x/callback for local)

# ---------------------------------------------------------------------------
# Anthropic (Claude) - writes the posts and ranks trends
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
GENERATION_MODEL=claude-haiku-4-5   # default model; bump to claude-opus-4-8 or claude-fable-5 for better voice

# ---------------------------------------------------------------------------
# Cron
# ---------------------------------------------------------------------------
CRON_SECRET=                 # bearer token; set the same value in Vercel and in the cron-job.org request header

# Public base URL (used to build absolute links)
APP_URL=http://localhost:3000
